<Activity mc:Ignorable="sap sap2010" x:Class="Erp_FindVendor" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation" xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation" xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib" xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib" xmlns:sd="clr-namespace:System.Data;assembly=System.Data.Common" xmlns:ui="http://schemas.uipath.com/workflow/activities" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members><x:Property Name="in_Connection" Type="InArgument(ui:DatabaseConnection)" /><x:Property Name="in_Supplier" Type="InArgument(x:String)" /><x:Property Name="in_IBAN" Type="InArgument(x:String)" /><x:Property Name="out_VendorId" Type="OutArgument(x:Int32)" /><x:Property Name="out_IsFound" Type="OutArgument(x:Boolean)" /></x:Members>
  <VisualBasic.Settings><x:Null /></VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation><sco:Collection x:TypeArguments="x:String"><x:String>System</x:String><x:String>System.Data</x:String><x:String>Microsoft.VisualBasic</x:String><x:String>UiPath.Database</x:String><x:String>UiPath.Database.Activities</x:String></sco:Collection></TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation><sco:Collection x:TypeArguments="AssemblyReference"><AssemblyReference>System</AssemblyReference><AssemblyReference>System.Activities</AssemblyReference><AssemblyReference>System.Data</AssemblyReference><AssemblyReference>System.Data.Common</AssemblyReference><AssemblyReference>System.Private.CoreLib</AssemblyReference><AssemblyReference>Microsoft.VisualBasic</AssemblyReference><AssemblyReference>UiPath.Database</AssemblyReference><AssemblyReference>UiPath.Database.Activities</AssemblyReference><AssemblyReference>UiPath.System.Activities</AssemblyReference></sco:Collection></TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="Erp_FindVendor"><Sequence.Variables><Variable x:TypeArguments="sd:DataTable" Name="dtVendor" /></Sequence.Variables>
    <ui:ExecuteQuery ContinueOnError="{x:Null}" TimeoutMS="{x:Null}" DataTable="[dtVendor]" DisplayName="Find Vendor In Vendor Table" ExistingDbConnection="[in_Connection]" Sql="SELECT vendorid FROM vendors WHERE LOWER(name) = LOWER(?) OR iban = ? LIMIT 1;"><ui:ExecuteQuery.Parameters><InArgument x:TypeArguments="x:String" x:Key="Name">[in_Supplier]</InArgument><InArgument x:TypeArguments="x:String" x:Key="Iban">[in_IBAN]</InArgument></ui:ExecuteQuery.Parameters></ui:ExecuteQuery>
    <Assign><Assign.To><OutArgument x:TypeArguments="x:Boolean">[out_IsFound]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Boolean">[dtVendor IsNot Nothing AndAlso dtVendor.Rows.Count &gt; 0]</InArgument></Assign.Value></Assign>
    <If Condition="[out_IsFound]"><If.Then><Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[out_VendorId]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[Convert.ToInt32(dtVendor.Rows(0)("vendorid"))]</InArgument></Assign.Value></Assign></If.Then><If.Else><Assign><Assign.To><OutArgument x:TypeArguments="x:Int32">[out_VendorId]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">0</InArgument></Assign.Value></Assign></If.Else></If>
    <ui:LogMessage DisplayName="Log ERP Find" Level="Info" Message="[If(out_IsFound, &quot;Vendor found in vendor table&quot;, &quot;Vendor not found in vendor table&quot;)]" />
  </Sequence>
</Activity>
