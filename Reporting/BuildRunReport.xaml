<Activity mc:Ignorable="sap sap2010" x:Class="BuildRunReport" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation" xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation" xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib" xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib" xmlns:sd="clr-namespace:System.Data;assembly=System.Data.Common" xmlns:si="clr-namespace:System.IO;assembly=System.Private.CoreLib" xmlns:ui="http://schemas.uipath.com/workflow/activities" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members><x:Property Name="in_Connection" Type="InArgument(ui:DatabaseConnection)" /><x:Property Name="in_ReportFolder" Type="InArgument(x:String)" /><x:Property Name="out_ReportPath" Type="OutArgument(x:String)" /></x:Members>
  <VisualBasic.Settings><x:Null /></VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation><sco:Collection x:TypeArguments="x:String"><x:String>System</x:String><x:String>System.Data</x:String><x:String>System.IO</x:String><x:String>Microsoft.VisualBasic</x:String><x:String>UiPath.Database</x:String><x:String>UiPath.Database.Activities</x:String></sco:Collection></TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation><sco:Collection x:TypeArguments="AssemblyReference"><AssemblyReference>System</AssemblyReference><AssemblyReference>System.Activities</AssemblyReference><AssemblyReference>System.Data</AssemblyReference><AssemblyReference>System.Data.Common</AssemblyReference><AssemblyReference>System.Private.CoreLib</AssemblyReference><AssemblyReference>Microsoft.VisualBasic</AssemblyReference><AssemblyReference>UiPath.Database</AssemblyReference><AssemblyReference>UiPath.Database.Activities</AssemblyReference><AssemblyReference>UiPath.System.Activities</AssemblyReference></sco:Collection></TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="BuildRunReport"><Sequence.Variables><Variable x:TypeArguments="sd:DataTable" Name="dtReport" /><Variable x:TypeArguments="x:String" Name="reportText" /><Variable x:TypeArguments="si:DirectoryInfo" Name="createdDirectory" /></Sequence.Variables>
    <Assign DisplayName="Create Report Folder"><Assign.To><OutArgument x:TypeArguments="si:DirectoryInfo">[createdDirectory]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="si:DirectoryInfo">[Directory.CreateDirectory(in_ReportFolder)]</InArgument></Assign.Value></Assign>
    <ui:ExecuteQuery ContinueOnError="{x:Null}" TimeoutMS="{x:Null}" DataTable="[dtReport]" DisplayName="Read Process Log Summary" ExistingDbConnection="[in_Connection]" Sql="SELECT COUNT(*) AS total_processed, SUM(CASE WHEN status = 'SUCCESS' THEN 1 ELSE 0 END) AS successful, SUM(CASE WHEN status = 'BUSINESS_EXCEPTION' THEN 1 ELSE 0 END) AS business_exceptions, SUM(CASE WHEN status = 'SYSTEM_EXCEPTION' THEN 1 ELSE 0 END) AS system_exceptions, SUM(CASE WHEN status = 'DUPLICATE' THEN 1 ELSE 0 END) AS duplicates, SUM(CASE WHEN status = 'VALIDATION_FAILED' THEN 1 ELSE 0 END) AS validation_failures FROM process_logs;"><ui:ExecuteQuery.Parameters><scg:Dictionary x:TypeArguments="x:String, Argument" /></ui:ExecuteQuery.Parameters></ui:ExecuteQuery>
    <Assign DisplayName="Build Report Text"><Assign.To><OutArgument x:TypeArguments="x:String">[reportText]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Invoice2DB Run Report" &amp; Environment.NewLine &amp; "Generated: " &amp; DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss") &amp; Environment.NewLine &amp; "Total processed: " &amp; dtReport.Rows(0)("total_processed").ToString &amp; Environment.NewLine &amp; "Successful: " &amp; dtReport.Rows(0)("successful").ToString &amp; Environment.NewLine &amp; "Business exceptions: " &amp; dtReport.Rows(0)("business_exceptions").ToString &amp; Environment.NewLine &amp; "System exceptions: " &amp; dtReport.Rows(0)("system_exceptions").ToString &amp; Environment.NewLine &amp; "Duplicates: " &amp; dtReport.Rows(0)("duplicates").ToString &amp; Environment.NewLine &amp; "Validation failures: " &amp; dtReport.Rows(0)("validation_failures").ToString]</InArgument></Assign.Value></Assign>
    <Assign DisplayName="Build Report Path"><Assign.To><OutArgument x:TypeArguments="x:String">[out_ReportPath]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[Path.Combine(in_ReportFolder, "Invoice2DB_Report_" &amp; DateTime.Now.ToString("yyyyMMdd_HHmmss") &amp; ".txt")]</InArgument></Assign.Value></Assign>
    <InvokeMethod DisplayName="Write Report File" MethodName="WriteAllText" TargetType="si:File"><InvokeMethod.Parameters><InArgument x:TypeArguments="x:String">[out_ReportPath]</InArgument><InArgument x:TypeArguments="x:String">[reportText]</InArgument></InvokeMethod.Parameters></InvokeMethod>
    <ui:LogMessage DisplayName="Log Report" Level="Info" Message="[&quot;Run report saved to: &quot; &amp; out_ReportPath]" />
  </Sequence>
</Activity>
