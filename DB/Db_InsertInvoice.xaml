  <TextExpression.NamespacesForImplementation><sco:Collection x:TypeArguments="x:String"><x:String>System</x:String><x:String>System.Data</x:String><x:String>System.Globalization</x:String><x:String>System.Text.RegularExpressions</x:String><x:String>Microsoft.VisualBasic</x:String><x:String>UiPath.Database</x:String><x:String>UiPath.Database.Activities</x:String></sco:Collection></TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation><sco:Collection x:TypeArguments="AssemblyReference"><AssemblyReference>System</AssemblyReference><AssemblyReference>System.Activities</AssemblyReference><AssemblyReference>System.Data</AssemblyReference><AssemblyReference>System.Data.Common</AssemblyReference><AssemblyReference>System.Private.CoreLib</AssemblyReference><AssemblyReference>System.Text.RegularExpressions</AssemblyReference><AssemblyReference>Microsoft.VisualBasic</AssemblyReference><AssemblyReference>UiPath.Database</AssemblyReference><AssemblyReference>UiPath.Database.Activities</AssemblyReference><AssemblyReference>UiPath.System.Activities</AssemblyReference></sco:Collection></TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="Db_InsertInvoice"><Sequence.Variables><Variable x:TypeArguments="sd:DataTable" Name="dtResult" /><Variable x:TypeArguments="x:Decimal" Name="amountDecimal" /></Sequence.Variables>
    <Assign DisplayName="Normalize Amount"><Assign.To><OutArgument x:TypeArguments="x:Decimal">[amountDecimal]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Decimal">[Decimal.Parse(Regex.Replace(If(in_Amount, String.Empty), "[^\d\.,]", "").Replace(",", "."), CultureInfo.InvariantCulture)]</InArgument></Assign.Value></Assign>
    <ui:ExecuteQuery ContinueOnError="{x:Null}" TimeoutMS="{x:Null}" DataTable="[dtResult]" DisplayName="Insert Invoice" ExistingDbConnection="[in_Connection]" Sql="INSERT INTO invoices (mailid, vendorid, referenceid, amount, iban, status, createdat) VALUES (?, ?, ?, ?, ?, ?, NOW()) RETURNING invoiceid;"><ui:ExecuteQuery.Parameters><InArgument x:TypeArguments="x:Int32" x:Key="MailId">[in_MailId]</InArgument><InArgument x:TypeArguments="x:Int32" x:Key="VendorId">[in_VendorId]</InArgument><InArgument x:TypeArguments="x:String" x:Key="ReferenceId">[in_ReferenceId]</InArgument><InArgument x:TypeArguments="x:Decimal" x:Key="Amount">[amountDecimal]</InArgument><InArgument x:TypeArguments="x:String" x:Key="Iban">[in_IBAN]</InArgument><InArgument x:TypeArguments="x:String" x:Key="Status">[If(String.IsNullOrWhiteSpace(in_Status), "SUCCESS", in_Status)]</InArgument></ui:ExecuteQuery.Parameters></ui:ExecuteQuery>
    <Assign DisplayName="Return Invoice ID"><Assign.To><OutArgument x:TypeArguments="x:Int32">[out_InvoiceId]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:Int32">[Convert.ToInt32(dtResult.Rows(0)("invoiceid"))]</InArgument></Assign.Value></Assign>
