<Activity mc:Ignorable="sap sap2010" x:Class="Db_OpenConnection" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation" xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation" xmlns:scg="clr-namespace:System.Collections.Generic;assembly=System.Private.CoreLib" xmlns:sco="clr-namespace:System.Collections.ObjectModel;assembly=System.Private.CoreLib" xmlns:ui="http://schemas.uipath.com/workflow/activities" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members><x:Property Name="out_database" Type="OutArgument(ui:DatabaseConnection)" /></x:Members>
  <VisualBasic.Settings><x:Null /></VisualBasic.Settings>
  <TextExpression.NamespacesForImplementation><sco:Collection x:TypeArguments="x:String"><x:String>System</x:String><x:String>Microsoft.VisualBasic</x:String><x:String>UiPath.Database</x:String><x:String>UiPath.Database.Activities</x:String></sco:Collection></TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation><sco:Collection x:TypeArguments="AssemblyReference"><AssemblyReference>System</AssemblyReference><AssemblyReference>System.Activities</AssemblyReference><AssemblyReference>System.Data</AssemblyReference><AssemblyReference>System.Data.Common</AssemblyReference><AssemblyReference>System.Private.CoreLib</AssemblyReference><AssemblyReference>Microsoft.VisualBasic</AssemblyReference><AssemblyReference>UiPath.Database</AssemblyReference><AssemblyReference>UiPath.Database.Activities</AssemblyReference><AssemblyReference>UiPath.System.Activities</AssemblyReference></sco:Collection></TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="Db_OpenConnection">
    <Sequence.Variables><Variable x:TypeArguments="ui:DatabaseConnection" Name="database" /><Variable x:TypeArguments="x:String" Name="dbDsn" /><Variable x:TypeArguments="x:String" Name="dbUser" /><Variable x:TypeArguments="x:String" Name="dbPassword" /><Variable x:TypeArguments="x:String" Name="connectionString" /></Sequence.Variables>
    <Assign DisplayName="Read DSN"><Assign.To><OutArgument x:TypeArguments="x:String">[dbDsn]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[If(String.IsNullOrWhiteSpace(Environment.GetEnvironmentVariable("INVOICE2DB_DSN")), "PostgreSQL35W", Environment.GetEnvironmentVariable("INVOICE2DB_DSN"))]</InArgument></Assign.Value></Assign>
    <Assign DisplayName="Read DB User"><Assign.To><OutArgument x:TypeArguments="x:String">[dbUser]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[Environment.GetEnvironmentVariable(If(String.IsNullOrWhiteSpace(Environment.GetEnvironmentVariable("INVOICE2DB_DB_USER_ENVVAR")), "INVOICE2DB_DB_USER", Environment.GetEnvironmentVariable("INVOICE2DB_DB_USER_ENVVAR")))]</InArgument></Assign.Value></Assign>
    <Assign DisplayName="Read DB Password"><Assign.To><OutArgument x:TypeArguments="x:String">[dbPassword]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">[Environment.GetEnvironmentVariable(If(String.IsNullOrWhiteSpace(Environment.GetEnvironmentVariable("INVOICE2DB_DB_PASSWORD_ENVVAR")), "INVOICE2DB_DB_PASSWORD", Environment.GetEnvironmentVariable("INVOICE2DB_DB_PASSWORD_ENVVAR")))]</InArgument></Assign.Value></Assign>
    <Assign DisplayName="Build Connection String"><Assign.To><OutArgument x:TypeArguments="x:String">[connectionString]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="x:String">["Dsn=" &amp; dbDsn &amp; If(String.IsNullOrWhiteSpace(dbUser), String.Empty, ";uid=" &amp; dbUser) &amp; If(String.IsNullOrWhiteSpace(dbPassword), String.Empty, ";pwd=" &amp; dbPassword)]</InArgument></Assign.Value></Assign>
    <ui:LogMessage DisplayName="Log DB Connect" Level="Info" Message="[&quot;Opening database connection using configured DSN: &quot; &amp; dbDsn]" />
    <ui:DatabaseConnect DisplayName="Connect to Database" ProviderName="System.Data.Odbc" ConnectionString="[connectionString]" DatabaseConnection="[database]" />
    <Assign DisplayName="Return Connection"><Assign.To><OutArgument x:TypeArguments="ui:DatabaseConnection">[out_database]</OutArgument></Assign.To><Assign.Value><InArgument x:TypeArguments="ui:DatabaseConnection">[database]</InArgument></Assign.Value></Assign>
  </Sequence>
</Activity>

