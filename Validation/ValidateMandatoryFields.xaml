  <x:Members><x:Property Name="in_Supplier" Type="InArgument(x:String)" /><x:Property Name="in_ReferenceId" Type="InArgument(x:String)" /><x:Property Name="in_Amount" Type="InArgument(x:String)" /><x:Property Name="in_IBAN" Type="InArgument(x:String)" /><x:Property Name="out_IsValid" Type="OutArgument(x:Boolean)" /><x:Property Name="out_Message" Type="OutArgument(x:String)" /></x:Members>
